{
  "name": "sdet-playwright-project",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript + Playwright SDET project scaffolded with the SDET Claude Code kit.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --ui",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "spec:gen": "openapi-typescript specs/openapi.yaml -o tests/api/generated/schema.d.ts",
    "spec:lint": "redocly lint specs/openapi.yaml",
    "spec:sync": "npm run spec:lint && npm run spec:gen",
    "lint": "eslint ",
    "lint:fix": "eslint  --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "verify": "bash scripts/verify.sh || true",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@playwright/test": "^1.50.0",
    "@redocly/cli": "^1.25.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.0.0",
    "fishery": "^2.2.2",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "openapi-fetch": "^0.13.0",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.3.0",
    "tsc-files": "^1.1.4",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "zod": "^3.23.0"
  }
}
