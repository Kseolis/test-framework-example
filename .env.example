# SDET project — environment template.
# Copy this file to .env.local and fill the values.
# .env.local is gitignored.
#
# Note: tests/infra/env.ts validates these via zod at import time.

# Base URLs
BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080

# Test users (create them in your seeding flow)
TEST_USER_EMAIL=user@example.com
TEST_USER_PASSWORD=changeme-local-only
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=changeme-local-only

# Determinism
SEED=1234

# Reporting (optional)
# ALLURE_RESULTS_DIR=allure-results
# CI=true
