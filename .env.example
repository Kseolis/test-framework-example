# SDET project — environment template.
# Copy this file to .env.local and fill the values.
# .env.local is gitignored.
#
# Note: tests/infra/env.ts validates these via zod at import time.

# Base URLs
# Sites under test
BASE_URL_FREEVPN=https://freevpnplanet.com/
BASE_URL_ACCOUNT=https://account.freevpnplanet.com/
BASE_URL_PERSONAL=https://personal.freevpnplanet.com/
BASE_URL_PLANETCONFIG=https://planetconfig.com/

# Determinism (Faker seed) — see docs/CONSTRAINTS.md §2.4
SEED=1234

# Synthetic email domain for factories (disposable, valid MX) — see CONSTRAINTS §2.4
# SYNTHETIC_EMAIL_DOMAIN=yopmail.com

# Set automatically by CI; gates worker count + forbidOnly
# CI=true
